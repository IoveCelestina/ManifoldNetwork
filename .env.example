# ── chat-demo 部署配置 ──────────────────────────────────────────
# 复制成 .env 再填值：cp .env.example .env

# sub2api 的地址（chat-demo 容器视角）
#   同机 docker 发布在 127.0.0.1:8080 → http://host.docker.internal:8080
#   走公网域名（不推荐，多绕一圈 Cloudflare）→ https://zstuacm.xyz
SUB2API_BASE=http://host.docker.internal:8080

# Cloudflare Tunnel 的 token：
# CF 面板 → Zero Trust → Networks → Tunnels → Create a tunnel → 复制 token
# 详细步骤见 DEPLOY.md 第 2 步
TUNNEL_TOKEN=

TZ=Asia/Shanghai

# 对话数据库：默认存进命名卷 manifold-chat-data（compose 已配 DB_PATH=/data/manifold.db）。
# 一般不用改；身份/计费仍走 sub2api，无需任何额外密钥。备份见 DEPLOY.md「数据与备份」。

# ── 按 IP 限流（默认开启，挡登录爆破 / 刷接口）────────────────────
# 真实客户端 IP 靠反代（Caddy）经 X-Forwarded-For 透传；本服务须跑在反代后面才有效。
# 校园共用出口 IP 的小团队若误伤，调大 BURST 即可。RATE_LIMIT=off 整体关闭（仅本地调试）。
# RATE_LIMIT=on
# RL_AUTH_BURST=20        # 登录类(/api/v1/auth/login*) 单 IP 突发上限
# RL_AUTH_WINDOW=600      #   多少秒内回满上述额度（默认 20 次 / 10 分钟）
# RL_GENERAL_BURST=120    # 通用(/api /v1 /store) 单 IP 突发上限
# RL_GENERAL_WINDOW=60    #   回满窗口（默认 120 次 / 分钟）

# ── 每账号会话存储配额（防单账号 / 泄露凭证撑爆磁盘）──────────────
# STORE_MAX_CONVERSATIONS=500            # 单账号最多保存对话条数
# STORE_MAX_BYTES_PER_USER=209715200     # 单账号对话总字节上限（默认 200MB，含 base64 图）
