# ── chat-demo 部署配置 ──────────────────────────────────────────
# 复制成 .env 再填值：cp .env.example .env

# sub2api 的地址（chat-demo 容器视角）
#   同机 docker 发布在 127.0.0.1:8080 → http://host.docker.internal:8080
#   走公网域名（不推荐，多绕一圈 Cloudflare）→ https://zstuacm.xyz
SUB2API_BASE=http://host.docker.internal:8080

# Cloudflare Tunnel 的 token：
# CF 面板 → Zero Trust → Networks → Tunnels → Create a tunnel → 复制 token
# 详细步骤见 DEPLOY.md 第 2 步
TUNNEL_TOKEN=

TZ=Asia/Shanghai
